# ── Priority 7: Google Integrations ──────────────────────────────────────────
# Create a project at https://console.cloud.google.com
# Enable: Google Search Console API, Google Analytics Data API, Google Analytics Admin API
# Create OAuth 2.0 credentials (Web application type)
# Add authorized redirect URI: https://your-backend.onrender.com/api/integrations/google/oauth/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/integrations/google/oauth/callback

# After OAuth the user is redirected back here
FRONTEND_URL=http://localhost:5173

# Token encryption key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Required for production.
ENCRYPTION_KEY=your-64-hex-character-encryption-key-here
